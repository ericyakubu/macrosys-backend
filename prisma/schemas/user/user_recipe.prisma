model UserRecipe {
  id           String  @id @default(uuid())
  user_id      String
  name         String
  // diet_type_id String
  cook_time    Int?
  description  String?
  instructions String? @db.Text
  prep_time    Int?
  servings     Int?

  calories      Decimal? @db.Decimal(8,2)
  carbohydrates Decimal? @db.Decimal(6,2)
  fat           Decimal? @db.Decimal(6,2)
  fiber         Decimal? @db.Decimal(6,2)
  protein       Decimal? @db.Decimal(6,2)
  sugar         Decimal? @db.Decimal(6,2)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user     User                @relation(fields: [user_id], references: [id])
  // diet_type Diet                @relation(fields: [diet_type_id], references: [id])
  diets    Diet[]
  products UserRecipeProduct[]
  // macros   UserRecipeMacros?
  photo    UserRecipePhoto?
}

model UserRecipePhoto {
  id             String @id @default(uuid())
  user_recipe_id String @unique
  url            String

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  recipe UserRecipe @relation(fields: [user_recipe_id], references: [id], onDelete: Cascade)
}

model UserRecipeProduct {
  id              String @id @default(uuid())
  recipe_id       String
  user_product_id String
  product_id      String
  quantity        Int

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  recipe       UserRecipe  @relation(fields: [recipe_id], references: [id], onDelete: Cascade)
  user_product UserProduct? @relation(fields: [user_product_id], references: [id], onDelete: Cascade)
  product      Product?     @relation(fields: [product_id], references: [id], onDelete: Cascade)
}
