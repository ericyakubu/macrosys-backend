model UserProduct {
  id          String   @id @default(uuid())
  user_id     String
  name        String
  barcode     String?
  description String?
  rating      Float?

  calories      Decimal? @db.Decimal(8,2)
  carbohydrates Decimal? @db.Decimal(6,2)
  fat           Decimal? @db.Decimal(6,2)
  fiber         Decimal? @db.Decimal(6,2)
  protein       Decimal? @db.Decimal(6,2)
  sugar         Decimal? @db.Decimal(6,2)

  // macros UserProductMacros?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user                User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  photo               UserProductPhoto?
  user_recipe_product UserRecipeProduct[]
  // diet                Diet?               @relation(fields: [diet_id], references: [id])
  // diet_id              String?
  diets                Diet[]
}

model UserProductPhoto {
  id              String @id @default(uuid())
  user_product_id String @unique
  url             String

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  product UserProduct @relation(fields: [user_product_id], references: [id], onDelete: Cascade)
}

