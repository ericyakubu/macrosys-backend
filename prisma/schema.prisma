enum DietSourceEnum {
  SYSTEM
  TRAINER
  STAFF
}

model Diet {
  id String @id @default(uuid())

  name        String
  description String?

  source DietSourceEnum @default(SYSTEM)

  trainer_id String?
  created_by String?

  is_active Boolean @default(true)
  is_system Boolean @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  trainer Trainer? @relation(fields: [trainer_id], references: [id])

  user_recipes UserRecipe[]
  products     UserProduct[]
  recipe       Recipe?       @relation(fields: [recipeId], references: [id])
  recipeId     String?

  @@unique([trainer_id, name])
  @@index([source])
}

model UserPlan {
  id               String    @id @default(uuid())
  name             String
  price            Decimal
  discount_price   Decimal?
  discount_percent Decimal?
  sale_start       DateTime?
  sale_end         DateTime?
  available        Boolean   @default(true)
  description      String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  users UserSubscription[]
}

model TrainerPlan {
  id    String  @id @default(uuid())
  name  String
  price Decimal

  max_clients      Int?
  advanced_reports Boolean @default(false)
  description      String?

  discount_price   Decimal?
  discount_percent Decimal?
  sale_start       DateTime?
  sale_end         DateTime?

  available Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  trainers TrainerSubscription[]
}
