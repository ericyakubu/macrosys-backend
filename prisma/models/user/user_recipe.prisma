model UserRecipePhoto {
  id             String @id @default(uuid())
  user_recipe_id String @unique
  url            String

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  recipe UserRecipe @relation(fields: [user_recipe_id], references: [id], onDelete: Cascade)
}

model UserRecipeProduct {
  id              String @id @default(uuid())
  recipe_id       String
  user_product_id String
  product_id      String
  quantity        Int

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  recipe       UserRecipe  @relation(fields: [recipe_id], references: [id], onDelete: Cascade)
  user_product UserProduct @relation(fields: [user_product_id], references: [id], onDelete: Cascade)
  product      Product     @relation(fields: [product_id], references: [id], onDelete: Cascade)
}
