model UserRecipe {
  id           String  @id @default(uuid())
  user_id      String
  name         String
  // diet_type_id String
  cook_time    Int?
  description  String?
  instructions String? @db.Text
  prep_time    Int?
  servings     Int?

  total_calories      Decimal?
  total_carbohydrates Decimal?
  total_fat           Decimal?
  total_protein       Decimal?
  total_fiber         Decimal?
  total_sugar         Decimal?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user     User                @relation(fields: [user_id], references: [id])
  // diet_type Diet                @relation(fields: [diet_type_id], references: [id])
  diets    Diet[]
  products UserRecipeProduct[]
  // macros   UserRecipeMacros?
  photo    UserRecipePhoto?
}

